# 企业微信 JS-SDK：复制本文件为「部署目录下的 .env」后填写真实值
#
# 服务器部署（与 deploy.sh 中 APP_DIR 一致，默认 /opt/dcc_04.30）：
#   cp env.example /opt/dcc_04.30/.env
#   vim /opt/dcc_04.30/.env
#   再执行 sudo ./deploy.sh（构建时会读入 NEXT_PUBLIC_*）
#
# 本地开发：可将下面三项复制到 frontend/.env.local
#
# —— 前端：在 next build 时打入浏览器，修改后需重新 build ——
NEXT_PUBLIC_WECOM_CORP_ID=wwad89f0949783c9f1
NEXT_PUBLIC_WECOM_AGENT_ID=1000053
NEXT_PUBLIC_VCONSOLE=1
#
# —— 后端：uvicorn 运行时读取，与企业管理后台「自建应用」一致 ——
# WECOM_CORP_ID 与 NEXT_PUBLIC_WECOM_CORP_ID 填同一企业 ID
WECOM_CORP_ID=wwad89f0949783c9f1
WECOM_CORP_SECRET=OS8wmyZZ5GH_oBlFAX5zq08SZAy1z7vY0X3SNTtNb70
